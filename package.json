
{
  "name": "statbridge-app",
  "version": "1.0.0",
  "description": "StatBridge - Where Business meets Data",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run build-css\" \"electron . --dev\"",
    "build": "npm run build-css && electron-builder",
    "build-css": "tailwindcss -i ./src/styles/input.css -o ./src/styles/output.css --watch"
  },
  "keywords": ["electron", "react", "statistics", "desktop"],
  "author": "StatBridge Team",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.0",
    "concurrently": "^8.2.0",
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0",
    "tailwindcss": "^3.3.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.statbridge.app",
    "productName": "StatBridge App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ]
  }
}